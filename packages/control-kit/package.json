{
  "name": "control-kit",
  "version": "0.1.0",
  "description": "Lab System 设备控制组件库 - 基于 Vue3 + TypeScript",
  "type": "module",
  "main": "./dist/control-kit.umd.js",
  "module": "./dist/control-kit.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/control-kit.es.js",
      "require": "./dist/control-kit.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vue-tsc": "^3.2.6"
  },
  "keywords": [
    "vue3",
    "typescript",
    "device-control",
    "lab-system",
    "components"
  ],
  "author": "",
  "license": "MIT"
}
